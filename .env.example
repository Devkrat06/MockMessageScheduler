# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://scheduler:secret@localhost:5432/scheduler

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_NAME=message-scheduler
WORKER_CONCURRENCY=5
MAX_RETRIES=3

# ── WhatsApp Messaging Provider ───────────────────────────────────────────────
# Options: mock | business_api
# Use 'mock' for local development (no real messages sent)
# Use 'business_api' for production with the WhatsApp Business Cloud API
WHATSAPP_PROVIDER=mock

# Required when WHATSAPP_PROVIDER=business_api
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to your Chrome Extension origin:
#   chrome-extension://YOUR_EXTENSION_ID
# Comma-separated for multiple origins.
ALLOWED_ORIGINS=*
